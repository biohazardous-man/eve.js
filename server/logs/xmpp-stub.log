[2026-04-14T16:41:55.099Z] OUT <presence from='corp_1000060@conference.localhost/140000227' to='140000227@localhost/evejs' id='id6'><eve_user_data corpid='1000060' allianceid='0' warfactionid='0' typeid='1386' role='7348784299939993600' info='{&quot;ownerID&quot;:140000227,&quot;ownerName&quot;:&quot;Aldik Dren&quot;,&quot;name&quot;:&quot;Aldik Dren&quot;,&quot;typeID&quot;:1386}'/><x xmlns='http://jabber.org/protocol/muc#user'><item affiliation='member' role='participant' jid='140000227@localhost/evejs'/><status code='110'/></x></presence>
[2026-04-14T16:42:21.197Z] OUT <message from='local_30100032@conference.localhost/admin' to='140000227@localhost/evejs' type='groupchat' id='evejs-1776184941196-2'><body>{&quot;cmd&quot;:&quot;speak&quot;,&quot;charid&quot;:1,&quot;messageText&quot;:&quot;Spawned 3 transient Drifter Battleship /drifter hulls on the native NPC path. Drifter hull effects, turbo-shield presentation, and superweapon sequencing now ride the native combat path instead of a fake fitted-module harness.&quot;}</body></message>
